--
-- Name: categories Allow public read access to categories; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Allow public read access to categories" ON public.categories FOR SELECT TO anon USING (true);


--
-- Name: link_stats Anyone can insert link stats; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can insert link stats" ON public.link_stats FOR INSERT WITH CHECK (true);


--
-- Name: short_urls Anyone can view active urls; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can view active urls" ON public.short_urls FOR SELECT TO authenticated USING ((is_active = true));


--
-- Name: article_tags Anyone can view tags of published articles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Anyone can view tags of published articles" ON public.article_tags FOR SELECT TO authenticated USING ((EXISTS ( SELECT 1
   FROM public.articles
  WHERE ((articles.id = article_tags.article_id) AND (articles.status = 'published'::text)))));


--
-- Name: article_history Artículos publicados visibles para todos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Artículos publicados visibles para todos" ON public.article_history FOR SELECT USING ((status = 'published'::text));


--
-- Name: archived_links Authenticated users can insert archived links; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Authenticated users can insert archived links" ON public.archived_links FOR INSERT TO authenticated WITH CHECK (true);


--
-- Name: posts Cualquiera puede ver posts publicados; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Cualquiera puede ver posts publicados" ON public.posts FOR SELECT USING ((published = true));


--
-- Name: user_roles Los usuarios pueden ver roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Los usuarios pueden ver roles" ON public.user_roles FOR SELECT USING ((auth.role() = 'authenticated'::text));


--
-- Name: user_roles Permitir actualización a admin; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Permitir actualización a admin" ON public.user_roles FOR UPDATE USING (true);


--
-- Name: user_roles Permitir escritura a admin; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Permitir escritura a admin" ON public.user_roles FOR INSERT WITH CHECK (true);


--
-- Name: user_roles Permitir lectura a todos; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Permitir lectura a todos" ON public.user_roles FOR SELECT USING (true);


--
-- Name: articles Published articles are visible to all; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Published articles are visible to all" ON public.articles FOR SELECT TO authenticated USING ((status = 'published'::text));


--
-- Name: user_roles Solo administradores pueden modificar roles; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Solo administradores pueden modificar roles" ON public.user_roles USING ((auth.email() = 'ernesto.rodriguez120289@gmail.com'::text));


--
-- Name: short_urls Users can manage their own urls; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage their own urls" ON public.short_urls TO authenticated USING ((user_id = auth.uid()));


--
-- Name: categories Users can view active categories; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view active categories" ON public.categories FOR SELECT TO authenticated USING ((is_active = true));


--
-- Name: navigation_modules Users can view active modules; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view active modules" ON public.navigation_modules FOR SELECT TO authenticated USING ((is_active = true));


--
-- Name: tags Users can view active tags; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view active tags" ON public.tags FOR SELECT TO authenticated USING ((is_active = true));


--
-- Name: user_stats Users can view own stats; Type: POLICY; Schema: public; Owner: postgres
