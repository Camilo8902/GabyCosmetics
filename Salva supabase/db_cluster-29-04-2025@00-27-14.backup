--
-- Name: get_dashboard_stats(uuid, integer); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.get_dashboard_stats(p_user_id uuid, p_days integer DEFAULT 30) RETURNS TABLE(total_clicks bigint, total_links bigint, average_cpm numeric, recent_clicks json)
    LANGUAGE plpgsql
    AS $$
BEGIN
  RETURN QUERY
  WITH daily_stats AS (
    SELECT 
      date_trunc('day', s.created_at)::date as day,
      COUNT(DISTINCT l.id) as total_links,
      SUM(s.clicks) as daily_clicks
    FROM links l
    LEFT JOIN link_stats s ON l.id = s.link_id
    WHERE l.user_id = p_user_id
    AND s.created_at >= current_date - (p_days || ' days')::interval
    GROUP BY date_trunc('day', s.created_at)::date
  )
  SELECT
    COALESCE(SUM(l.clicks), 0)::bigint as total_clicks,
    COUNT(DISTINCT l.id)::bigint as total_links,
    COALESCE(AVG(l.clicks), 0)::numeric as average_cpm,
    COALESCE(
      (SELECT json_object_agg(
        day::text, 
        COALESCE(daily_clicks, 0)
      )
      FROM generate_series(
        current_date - (p_days - 1 || ' days')::interval,
        current_date,
        '1 day'
      ) AS dates(day)
      LEFT JOIN daily_stats ON daily_stats.day = dates.day),
      '{}'::json
    )::json as recent_clicks
  FROM links l
  WHERE l.user_id = p_user_id;
END;
$$;


ALTER FUNCTION public.get_dashboard_stats(p_user_id uuid, p_days integer) OWNER TO postgres;

--
-- Name: get_dashboard_stats(uuid, text); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.get_dashboard_stats(p_user_id uuid, p_month text DEFAULT to_char((CURRENT_DATE)::timestamp with time zone, 'YYYY-MM'::text)) RETURNS TABLE(total_clicks bigint, total_links bigint, total_all_time_clicks bigint, average_cpm numeric, recent_clicks json)
    LANGUAGE plpgsql
    AS $$
DECLARE
  start_date date;
  end_date date;
BEGIN
  -- Convertir el mes seleccionado a fechas de inicio y fin
  start_date := (p_month || '-01')::date;
  end_date := (start_date + interval '1 month' - interval '1 day')::date;

  RETURN QUERY
  WITH monthly_stats AS (
    SELECT 
      l.id as link_id,
      COALESCE(SUM(ls.clicks), 0) as monthly_clicks
    FROM links l
    LEFT JOIN link_stats ls ON l.id = ls.link_id 
      AND ls.visit_date BETWEEN start_date AND end_date
    WHERE l.user_id = p_user_id
    GROUP BY l.id
  ),
  daily_stats AS (
    SELECT 
      ls.visit_date::date as visit_date,
      COALESCE(SUM(ls.clicks), 0) as daily_clicks
    FROM links l
    JOIN link_stats ls ON l.id = ls.link_id
    WHERE l.user_id = p_user_id
      AND ls.visit_date BETWEEN start_date AND end_date
    GROUP BY ls.visit_date::date
  )
  SELECT
    COALESCE((SELECT SUM(monthly_clicks) FROM monthly_stats), 0)::bigint,
    (SELECT COUNT(*) FROM links WHERE user_id = p_user_id)::bigint,
    COALESCE((
      SELECT SUM(ls.clicks)
      FROM links l
      JOIN link_stats ls ON l.id = ls.link_id
      WHERE l.user_id = p_user_id
    ), 0)::bigint,
    COALESCE((
      SELECT AVG(monthly_clicks)
      FROM monthly_stats
      WHERE monthly_clicks > 0
    ), 0)::numeric,
    COALESCE(
      (SELECT json_object_agg(
        dates.day::text, 
        COALESCE(ds.daily_clicks, 0)
      )
      FROM generate_series(
        start_date,
        end_date,
        '1 day'
      ) AS dates(day)
      LEFT JOIN daily_stats ds ON ds.visit_date = dates.day),
      '{}'::json
    )::json;
END;
$$;


ALTER FUNCTION public.get_dashboard_stats(p_user_id uuid, p_month text) OWNER TO postgres;

--
-- Name: get_link_stats_by_id(text); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.get_link_stats_by_id(p_link_id text) RETURNS TABLE(id uuid, link_id uuid, country_code text, clicks integer)
    LANGUAGE plpgsql
    AS $$
BEGIN
  RETURN QUERY
  SELECT 
    link_stats.id,
    link_stats.link_id,
    link_stats.country_code,
    link_stats.clicks
  FROM 
    link_stats
  WHERE 
    link_stats.link_id::TEXT = p_link_id
  ORDER BY 
    link_stats.clicks DESC;
END;
$$;


