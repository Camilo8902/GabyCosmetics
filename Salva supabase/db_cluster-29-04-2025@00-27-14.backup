--
-- Name: sync_user_email(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.sync_user_email() RETURNS trigger
    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
BEGIN
  IF TG_OP = 'INSERT' THEN
    INSERT INTO profiles (
      user_id,
      email,
      first_name,
      role,
      is_active
    ) VALUES (
      NEW.id,
      NEW.email,
      COALESCE(NEW.raw_user_meta_data->>'full_name', ''),
      'agent',
      true
    )
    ON CONFLICT (user_id) 
    DO UPDATE SET
      email = EXCLUDED.email,
      updated_at = now();
  ELSIF TG_OP = 'UPDATE' AND OLD.email <> NEW.email THEN
    UPDATE profiles
    SET 
      email = NEW.email,
      updated_at = now()
    WHERE user_id = NEW.id;
  END IF;
  RETURN NEW;
END;
$$;


ALTER FUNCTION public.sync_user_email() OWNER TO postgres;

--
-- Name: update_country_stats(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.update_country_stats() RETURNS trigger
    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
DECLARE
  v_user_id UUID;
BEGIN
  -- Obtener el user_id del enlace
  SELECT user_id INTO v_user_id
  FROM short_urls
  WHERE id = NEW.link_id;

  -- Actualizar o insertar estadísticas por país
  INSERT INTO link_stats (
    user_id,
    link_id,
    country_code,
    clicks,
    created_at,
    updated_at
  )
  VALUES (
    v_user_id,
    NEW.link_id,
    COALESCE(NEW.country_code, 'unknown'),
    1,
    NOW(),
    NOW()
  )
  ON CONFLICT (user_id, link_id, country_code)
  DO UPDATE SET
    clicks = link_stats.clicks + 1,
    updated_at = NOW();

  RETURN NEW;
END;
$$;


ALTER FUNCTION public.update_country_stats() OWNER TO postgres;

--
-- Name: update_link_stats(bigint, integer); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.update_link_stats(p_link_id bigint, p_clicks integer DEFAULT 1) RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- Insertar o actualizar estadísticas para la fecha actual
  INSERT INTO public.link_stats (link_id, visit_date, clicks)
  VALUES (p_link_id, current_date, p_clicks)
  ON CONFLICT (link_id, visit_date) 
  DO UPDATE SET 
    clicks = link_stats.clicks + p_clicks,
    updated_at = now();
END;
$$;


ALTER FUNCTION public.update_link_stats(p_link_id bigint, p_clicks integer) OWNER TO postgres;

--
-- Name: update_link_stats(bigint, text); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.update_link_stats(p_link_id bigint, p_country_code text DEFAULT NULL::text) RETURNS void
    LANGUAGE plpgsql
    AS $$
BEGIN
  -- Insertar o actualizar estadísticas diarias
  INSERT INTO public.link_stats (
    link_id,
    visit_date,
    country_code,
    clicks
  )
  VALUES (
    p_link_id,
    current_date,
    p_country_code,
    1
  )
  ON CONFLICT (link_id, visit_date, COALESCE(country_code, ''))
  DO UPDATE SET
    clicks = link_stats.clicks + 1;
    
  -- Actualizar el contador total en la tabla links
  UPDATE public.links
  SET clicks = clicks + 1
  WHERE id = p_link_id;
END;
$$;


ALTER FUNCTION public.update_link_stats(p_link_id bigint, p_country_code text) OWNER TO postgres;

