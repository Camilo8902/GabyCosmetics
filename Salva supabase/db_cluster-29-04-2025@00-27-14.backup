--
-- Name: permissions Users can view permissions; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view permissions" ON public.permissions FOR SELECT TO authenticated USING (true);


--
-- Name: link_stats Users can view their own link stats; Type: POLICY; Schema: public; Owner: postgres
