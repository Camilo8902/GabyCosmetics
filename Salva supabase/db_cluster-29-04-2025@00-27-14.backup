--
-- Name: increment_stats(bigint, date, text); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.increment_stats(p_link_id bigint, p_date date DEFAULT CURRENT_DATE, p_country_code text DEFAULT NULL::text) RETURNS void
    LANGUAGE plpgsql
    AS $$
DECLARE
  existing_record RECORD;
BEGIN
  -- Buscar si existe un registro para hoy
  SELECT * INTO existing_record 
  FROM public.link_stats 
  WHERE link_id = p_link_id 
    AND visit_date = p_date
    AND COALESCE(country_code, '') = COALESCE(p_country_code, '');
  
  IF FOUND THEN
    -- Actualizar registro existente
    UPDATE public.link_stats 
    SET clicks = clicks + 1,
        updated_at = now()
    WHERE id = existing_record.id;
  ELSE
    -- Crear nuevo registro
    INSERT INTO public.link_stats 
      (link_id, visit_date, clicks, country_code, created_at, updated_at)
    VALUES 
      (p_link_id, p_date, 1, p_country_code, now(), now());
  END IF;
  
  -- Actualizar contador principal en la tabla de enlaces
  UPDATE public.links
  SET clicks = clicks + 1,
      updated_at = now()
  WHERE id = p_link_id;
END;
$$;


ALTER FUNCTION public.increment_stats(p_link_id bigint, p_date date, p_country_code text) OWNER TO postgres;

--
-- Name: increment_url_visits(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.increment_url_visits() RETURNS trigger
    LANGUAGE plpgsql SECURITY DEFINER
    AS $$
BEGIN
  -- Incrementar visitas en short_urls
  UPDATE short_urls
  SET visits = visits + 1,
      updated_at = NOW()
  WHERE id = NEW.link_id;

  -- Actualizar o crear registro en user_stats
  INSERT INTO user_stats (user_id, total_links, total_visits, updated_at)
  VALUES (NEW.user_id, 1, 1, NOW())
  ON CONFLICT (user_id) DO UPDATE
  SET total_visits = user_stats.total_visits + 1,
      updated_at = NOW();

  RETURN NEW;
END;
$$;


ALTER FUNCTION public.increment_url_visits() OWNER TO postgres;

